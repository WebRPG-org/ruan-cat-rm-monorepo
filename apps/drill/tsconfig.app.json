{
	"extends": "@vue/tsconfig/tsconfig.dom.json",
	"include": [
		"env.d.ts",
		"./src/**/*",
		"./src/**/*.vue",
		// 导入自动生成的类型声明文件
		"auto-imports.d.ts",
		"components.d.ts",
		"./types/**/*.d.ts",
		// 包含全部的类型声明文件
		"./src/types/**/*.ts",
		// RPGMV 核心文件类型检查
		"./drill-project/js/main.js",
		"./drill-project/js/rpg_*.js",
		// RPGMV 插件类型检查
		"./drill-project/js/plugins/MOG_*.js",
		"./drill-project/js/plugins/YEP_*.js",
		"./drill-project/js/plugins/*ruancat*.js"
	],
	"exclude": [
		"./src/**/__tests__/*",
		// 不得不排除的文件
		"./drill-project/js/plugins/----*.js",
		"./drill-project/js/plugins.js",
		"./drill-project/js/libs",
		"./drill-project/js/libs/pixi*.js",
		"./drill-project/data",
		"./drill-project/audio",
		"./drill-project/img",
		"./drill-project/movies",
		"./drill-project/icon",
		"./drill-project/save",
		"./drill-project/index.html",
		"./drill-project/fonts",
		"node_modules"
	],
	"compilerOptions": {
		"composite": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"],
			"components/*": ["src/components/*"]
		},
		// 项目特有的类型声明
		"types": [
			// Element Plus 全局类型
			"element-plus/global.d.ts",
			// Node.js 兼容层类型声明（浏览器中模拟 Node.js API）
			"node",
			// RPGMV 相关类型库
			"fpsmeter",
			"lz-string",
			// https://github.com/pixijs/pixi-typescript/tree/v4.5.4
			"pixi.js"
		],
		// 保持与项目兼容的配置
		"target": "ESNext",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"isolatedModules": true,
		"moduleDetection": "force",
		"jsx": "preserve",
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		// 禁用文件生成 - 只做类型检查，不生成任何输出文件
		"noEmit": true,
		"declaration": false,
		"declarationMap": false,
		"emitDeclarationOnly": false,
		"resolveJsonModule": true,
		"allowJs": true
	}
}
