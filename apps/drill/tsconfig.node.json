{
	"compilerOptions": {
		"composite": true,
		"target": "ES2022",
		"lib": ["ES2023"],
		"module": "ESNext",
		"skipLibCheck": true,
		/* Bundler mode */
		"moduleResolution": "bundler",
		"isolatedModules": true,
		"moduleDetection": "force",
		/* Linting */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		/* 禁用文件生成 - 只做类型检查，不生成任何输出文件 */
		"noEmit": true,
		"declaration": false,
		"declarationMap": false,
		"emitDeclarationOnly": false
	},
	"include": ["vite.config.ts", "./scripts", "./build"]
}
