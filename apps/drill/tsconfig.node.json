{
	"extends": "@tsconfig/node24/tsconfig.json",
	"include": [
		"vite.config.*",
		"vitest.config.*",
		"cypress.config.*",
		"nightwatch.conf.*",
		"playwright.config.*",
		"eslint.config.*",
		// 项目构建脚本
		"./scripts",
		"./build"
	],
	"compilerOptions": {
		"composite": true,
		"noEmit": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": ["node"],
		// 保持现代化的配置
		"target": "ES2022",
		"lib": ["ES2023"],
		"skipLibCheck": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"moduleDetection": "force"
	}
}
